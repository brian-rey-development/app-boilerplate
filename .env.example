# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Database (direct PostgreSQL connection for Drizzle)
DATABASE_URL=

# API
API_URL=http://localhost:3001
PORT=3001

# Web
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:3001
WEB_URL=http://localhost:5173

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Observability
LOG_LEVEL=debug
OTEL_EXPORTER_OTLP_ENDPOINT=

# Sentry
SENTRY_DSN=
VITE_SENTRY_DSN=

# Redis (optional -- leave empty to use in-memory rate limiting)
# To enable: set REDIS_URL, then swap the rate limiter in create-app.ts
# The building blocks are ready in shared/lib/redis.ts, rate-limiter.ts, and cache.ts
REDIS_URL=

# Email
RESEND_API_KEY=
EMAIL_FROM=

# Background Jobs
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Feature Flags (set to "true" or "false")
FEATURE_INVITE_MEMBERS=true
FEATURE_AI_CHAT=false
FEATURE_AUDIT_LOG=true

# E2E Testing
E2E_BASE_URL=http://localhost:5173
E2E_TEST_USER=
E2E_TEST_ORG=
